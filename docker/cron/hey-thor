#!/bin/sh
set -e

KEY=""
while [ $# -gt 1 ]; do
  case "$1" in
    --key) KEY="$2"; shift 2 ;;
    *) break ;;
  esac
done

[ -z "$1" ] && { echo "Usage: hey-thor [--key <key>] '<prompt>'"; exit 1; }

echo "[hey-thor] prompt length: ${#1}"
echo "[hey-thor] prompt preview: $(printf '%.80s' "$1")..."

JSON="{\"prompt\":$(printf '%s' "$1" | jq -Rs .)}"
[ -n "$KEY" ] && JSON="{\"prompt\":$(printf '%s' "$1" | jq -Rs .),\"correlationKey\":$(printf '%s' "$KEY" | jq -Rs .)}"

echo "[hey-thor] json length: ${#JSON}"
echo "[hey-thor] posting to ${GATEWAY_URL}/cron"

printf '%s' "$JSON" | curl -v -X POST "${GATEWAY_URL}/cron" \
  -H "Content-Type: application/json" \
  -H "Authorization: Bearer ${CRON_SECRET}" \
  -d @- 2>&1

echo ""
echo "[hey-thor] exit code: $?"
