#!/bin/sh
set -eu

REAL_CURL_BIN="${THOR_REAL_CURL_BIN:-/usr/bin/curl}"

is_slack_post_message=0
request_thread_ts=""
request_channel=""

check_post_message_url() {
  case "$1" in
    https://slack.com/api/chat.postMessage|https://slack.com/api/chat.postMessage\?*|http://slack.com/api/chat.postMessage|http://slack.com/api/chat.postMessage\?*)
      is_slack_post_message=1
      ;;
  esac
}

parse_form_value() {
  case "$1" in
    thread_ts=*)
      request_thread_ts="${1#thread_ts=}"
      ;;
    channel=*)
      request_channel="${1#channel=}"
      ;;
  esac
}

expect_value=0
expect_kind=""

for arg in "$@"; do
  if [ "$expect_value" -eq 1 ]; then
    case "$expect_kind" in
      url)
        check_post_message_url "$arg"
        ;;
      form)
        parse_form_value "$arg"
        ;;
    esac
    expect_value=0
    expect_kind=""
    continue
  fi

  case "$arg" in
    --url)
      expect_value=1
      expect_kind="url"
      ;;
    --url=*)
      check_post_message_url "${arg#--url=}"
      ;;
    --data-urlencode|--data|--data-raw|--data-binary|-d)
      expect_value=1
      expect_kind="form"
      ;;
    --data-urlencode=*|--data=*|--data-raw=*|--data-binary=*|-d=*)
      parse_form_value "${arg#*=}"
      ;;
    *)
      check_post_message_url "$arg"
      ;;
  esac
done

if [ "$is_slack_post_message" -ne 1 ]; then
  exec "$REAL_CURL_BIN" "$@"
fi

set -- "$@" -H "x-opencode-directory: ${THOR_OPENCODE_DIRECTORY:-}"

if [ -n "${THOR_OPENCODE_SESSION_ID:-}" ]; then
  set -- "$@" -H "x-opencode-session-id: ${THOR_OPENCODE_SESSION_ID}"
fi

if [ -n "${THOR_OPENCODE_CALL_ID:-}" ]; then
  set -- "$@" -H "x-opencode-call-id: ${THOR_OPENCODE_CALL_ID}"
fi

response_file="$(mktemp)"
trap 'rm -f "$response_file"' EXIT INT TERM

if "$REAL_CURL_BIN" "$@" >"$response_file"; then
  curl_status=0
else
  curl_status=$?
fi

cat "$response_file"

if [ "$curl_status" -ne 0 ]; then
  exit "$curl_status"
fi

response="$(cat "$response_file")"

node -e '
const response = process.argv[1] ?? "";
const requestChannelRaw = process.argv[2] ?? "";
const requestThreadRaw = process.argv[3] ?? "";

const decode = (value) => {
  if (!value) return "";
  try {
    return decodeURIComponent(value.replace(/\+/g, "%20"));
  } catch {
    return value;
  }
};

const requestChannel = decode(requestChannelRaw);
const requestThreadTs = decode(requestThreadRaw);

let parsed;
try {
  parsed = JSON.parse(response);
} catch {
  process.exit(0);
}

if (!parsed || parsed.ok !== true) process.exit(0);

const alias = requestThreadTs || parsed.ts || parsed.message?.thread_ts;
if (!alias) process.exit(0);

const context = requestThreadTs
  ? `Replied in thread in ${requestChannel || parsed.channel || "unknown"}`
  : `New thread posted to ${parsed.channel || requestChannel || "unknown"}`;

process.stderr.write(
  `[thor:meta] ${JSON.stringify({ type: "alias", alias: `slack:thread:${alias}`, context })}\n`,
);
' "$response" "$request_channel" "$request_thread_ts" || true

exit 0
