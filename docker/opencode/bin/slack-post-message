#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  slack-post-message --channel <id> [--thread-ts <ts>] (--text <text> | --text-file <path>)

Post a Slack message through the real Slack Web API while preserving Thor
thread alias metadata on stderr.

Options:
  --channel <id>      Channel ID (required)
  --thread-ts <ts>    Reply in an existing thread
  --text <text>       Message text
  --text-file <path>  Read message text from a file
  -h, --help          Show this help
EOF
}

die() {
  echo "slack-post-message: $*" >&2
  exit 1
}

require_value() {
  flag="$1"
  shift
  [ "$#" -gt 0 ] || die "missing value for $flag"
}

channel=""
thread_ts=""
text=""
text_file=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    --channel)
      shift
      require_value --channel "$@"
      channel="$1"
      ;;
    --thread-ts)
      shift
      require_value --thread-ts "$@"
      thread_ts="$1"
      ;;
    --text)
      shift
      require_value --text "$@"
      text="$1"
      ;;
    --text-file)
      shift
      require_value --text-file "$@"
      text_file="$1"
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    --)
      shift
      break
      ;;
    *)
      die "unknown option: $1"
      ;;
  esac
  shift
done

[ -n "$channel" ] || die "--channel is required"

if [ -n "$text" ] && [ -n "$text_file" ]; then
  die "use exactly one of --text or --text-file"
fi

if [ -z "$text" ] && [ -z "$text_file" ]; then
  die "one of --text or --text-file is required"
fi

if [ -n "$text_file" ]; then
  [ -f "$text_file" ] || die "text file not found: $text_file"
  [ -r "$text_file" ] || die "text file is not readable: $text_file"
fi

directory="${THOR_OPENCODE_DIRECTORY:-}"
[ -n "$directory" ] || die "THOR_OPENCODE_DIRECTORY is required for Slack writes"

set -- -sS -X POST https://slack.com/api/chat.postMessage \
  -H 'content-type: application/x-www-form-urlencoded' \
  -H "x-opencode-directory: $directory" \
  --data-urlencode "channel=$channel"

if [ -n "${THOR_OPENCODE_SESSION_ID:-}" ]; then
  set -- "$@" -H "x-opencode-session-id: ${THOR_OPENCODE_SESSION_ID}"
fi

if [ -n "${THOR_OPENCODE_CALL_ID:-}" ]; then
  set -- "$@" -H "x-opencode-call-id: ${THOR_OPENCODE_CALL_ID}"
fi

if [ -n "$thread_ts" ]; then
  set -- "$@" --data-urlencode "thread_ts=$thread_ts"
fi

if [ -n "$text_file" ]; then
  set -- "$@" --data-urlencode "text@$text_file"
else
  set -- "$@" --data-urlencode "text=$text"
fi

response_file="$(mktemp)"
trap 'rm -f "$response_file"' EXIT INT TERM

status="$(curl -o "$response_file" -w '%{http_code}' "$@")"

if [ "$status" != "200" ]; then
  cat "$response_file" >&2
  exit 1
fi

response="$(cat "$response_file")"
printf '%s\n' "$response"

node -e '
const response = process.argv[1];
const channel = process.argv[2] || "unknown";
const threadTs = process.argv[3] || "";

try {
  const parsed = JSON.parse(response);
  if (!parsed || parsed.ok !== true) process.exit(0);

  const alias = threadTs || parsed.ts;
  if (!alias) process.exit(0);

  const context = threadTs
    ? `Replied in thread in ${channel}`
    : `New thread posted to ${parsed.channel || channel}`;

  process.stderr.write(
    `[thor:meta] ${JSON.stringify({ type: "alias", alias: `slack:thread:${alias}`, context })}\n`,
  );
} catch {
  process.exit(0);
}
' "$response" "$channel" "$thread_ts"
