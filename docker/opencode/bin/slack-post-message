#!/bin/sh
set -eu

usage() {
  cat <<'EOF'
Usage:
  slack-post-message --channel <id> [--thread-ts <ts>] [--blocks-file <path>] [--file <path>]...

Post a Slack message through Thor's controlled remote-cli path.
Message input is stdin-only; positional text, --text, and --json are not supported.
Always pass --channel because Thor aliases store Slack thread timestamps, not channel IDs.
Stdin uses Slack mrkdwn: `*bold*`, `_italic_`, bullets, and code spans/fences.
For table or block output, pass --blocks-file.
Pass --file (repeatable) to attach files; each is uploaded into the thread with
the stdin message as its comment before the standalone message is posted.
Paths must be under /tmp or one of these shared workspace roots:
/workspace/memory, /workspace/config, /workspace/repos, /workspace/worklog,
/workspace/cron, /workspace/runs, or /workspace/worktrees.

Options:
  --channel <id>     Required Slack channel ID (C...)
  --thread-ts <ts>   Reply in an existing thread timestamp
  --blocks-file <p>  Optional JSON file with a top-level Slack blocks array
  --file <path>      Attach a file (repeatable) with stdin as its comment
  -h, --help         Show this help

Examples:
  echo 'Looking into this now.' | slack-post-message --channel C123 --thread-ts 1710000000.001

  echo 'Deployment looks healthy.' | \
    slack-post-message --channel C123 --blocks-file /tmp/blocks.json

  echo 'Attached the screenshots.' | \
    slack-post-message --channel C123 --file /tmp/before.png --file /tmp/after.png

  slack-post-message --channel C123 --thread-ts 1710000000.001 <<'MESSAGE'
  Root cause is a missing env var in the worker deploy.

  Next step: redeploy with FOO_API_KEY restored.
MESSAGE
EOF
}

case "${1:-}" in
  -h|--help)
    usage
    exit 0
    ;;
esac

exec node /usr/local/bin/remote-cli.mjs slack-post-message "$@"
