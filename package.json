{
  "name": "thor",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "clean": "pnpm -r clean",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:mcp": "node --import @oxc-node/core/register scripts/test-mcp.ts",
    "test:e2e": "./scripts/test-e2e.sh",
    "test:opencode-e2e": "./scripts/test-opencode-e2e.sh",
    "test:create-jira-approval-e2e": "./scripts/test-create-jira-approval-e2e.sh",
    "test:sandbox-e2e": "./scripts/test-sandbox-e2e.sh",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,json,md,yaml,yml}": "prettier --write"
  },
  "devDependencies": {
    "@oxc-node/core": "^0.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.22.1",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "^8.0.0"
    }
  }
}
