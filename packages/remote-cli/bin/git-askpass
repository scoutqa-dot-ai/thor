#!/bin/sh
# GIT_ASKPASS helper. Git invokes this with a prompt like:
#   Password for 'https://x-access-token@github.com/org/repo':
# The Node helper resolves the org from that prompt and prints the token to
# stdout.

TOKEN=$(node /app/packages/remote-cli/dist/auth-helper.js git-askpass "$1") || TOKEN=""
if [ -z "$TOKEN" ]; then
  exit 1
fi

printf '%s' "$TOKEN"
