#!/bin/sh
# Thor git wrapper — wires GIT_ASKPASS to the Thor helper for GitHub App
# installation tokens. Git only invokes askpass when a remote operation actually
# needs credentials, so local commands avoid the Node startup cost.

set -e

REAL_GIT="/usr/bin/git"

export GIT_ASKPASS="/usr/local/lib/thor/bin/git-askpass"
export GIT_TERMINAL_PROMPT=0
export GIT_CONFIG_COUNT=2
export GIT_CONFIG_KEY_0="credential.username"
export GIT_CONFIG_VALUE_0="x-access-token"
export GIT_CONFIG_KEY_1="credential.helper"
export GIT_CONFIG_VALUE_1=""
exec "$REAL_GIT" "$@"
