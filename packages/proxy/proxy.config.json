{
  "upstreams": {
    "linear": {
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer ${LINEAR_API_KEY}"
      }
    },
    "posthog": {
      "url": "https://mcp.posthog.com/mcp",
      "headers": {
        "Authorization": "Bearer ${POSTHOG_API_KEY}"
      }
    }
  },
  "policy": {
    "rules": [
      { "upstream": "linear", "toolPattern": "get_*", "action": "allow" },
      { "upstream": "linear", "toolPattern": "list_*", "action": "allow" },

      { "upstream": "posthog", "toolPattern": "*-get", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "*-get-all", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "*-get-definition", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "*-list", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "*-retrieve", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "*-search", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "*-stats", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "error-details", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "get-*", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "insight-query", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "list-errors", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "logs-*", "action": "allow" },
      { "upstream": "posthog", "toolPattern": "query-*", "action": "allow" },

      { "upstream": "*", "toolPattern": "*", "action": "block" }
    ]
  }
}
