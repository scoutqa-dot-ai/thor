{
  "upstream": {
    "url": "https://mcp.posthog.com/mcp",
    "headers": {
      "Authorization": "Bearer ${POSTHOG_API_KEY}"
    }
  },
  "allow": [
    "*-get",
    "*-get-all",
    "*-get-definition",
    "*-list",
    "*-retrieve",
    "*-search",
    "*-stats",
    "error-details",
    "get-*",
    "insight-query",
    "list-errors",
    "logs-*",
    "query-*"
  ]
}
