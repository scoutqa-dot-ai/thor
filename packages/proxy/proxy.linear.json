{
  "upstream": {
    "url": "https://mcp.linear.app/mcp",
    "headers": {
      "Authorization": "Bearer ${LINEAR_API_KEY}"
    }
  },
  "allow": [
    "list_comments",
    "get_issue",
    "list_issues",
    "list_issue_statuses",
    "get_issue_status",
    "list_projects",
    "get_project",
    "get_status_updates",
    "list_issue_labels",
    "list_project_labels",
    "extract_images",
    "get_attachment",
    "save_comment",
    "save_issue",
    "save_status_update"
  ],
  "approve": ["save_project"]
}
