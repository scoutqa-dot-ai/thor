{
  "upstream": {
    "url": "https://mcp.linear.app/mcp",
    "headers": {
      "Authorization": "Bearer ${LINEAR_API_KEY}"
    }
  },
  "allow": [
    "list_comments",
    "get_issue",
    "list_issues",
    "list_issue_statuses",
    "get_issue_status",
    "list_projects",
    "get_project",
    "list_teams",
    "get_team",
    "list_users",
    "get_user"
  ]
}
