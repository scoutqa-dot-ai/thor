{
  "upstream": {
    "url": "https://api.githubcopilot.com/mcp/x/all",
    "headers": {
      "Authorization": "Bearer ${GITHUB_PAT}"
    }
  },
  "allow": [
    "get_file_contents",
    "get_commit",
    "get_me",
    "issue_read",
    "list_branches",
    "list_commits",
    "list_pull_requests",
    "pull_request_read",
    "create_pull_request",
    "update_pull_request",
    "update_pull_request_branch",
    "add_issue_comment",
    "add_reply_to_pull_request_comment",
    "add_comment_to_pending_review",
    "get_gist",
    "get_latest_release",
    "get_release_by_tag",
    "get_tag",
    "list_releases",
    "list_tags",
    "actions_get",
    "actions_list",
    "get_job_logs",
    "pull_request_review_write"
  ],
  "approve": ["merge_pull_request", "actions_run_trigger", "create_gist"]
}
