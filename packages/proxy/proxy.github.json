{
  "upstream": {
    "url": "https://api.githubcopilot.com/mcp/x/all",
    "headers": {
      "Authorization": "Bearer ${GITHUB_PAT}"
    }
  },
  "allow": [
    "get_file_contents",
    "get_commit",
    "get_me",
    "issue_read",
    "list_branches",
    "list_commits",
    "list_issues",
    "list_pull_requests",
    "pull_request_read",
    "search_code",
    "search_issues",
    "search_pull_requests",
    "create_pull_request",
    "update_pull_request",
    "add_issue_comment",
    "add_reply_to_pull_request_comment",
    "pull_request_review_write",
    "add_comment_to_pending_review",
    "actions_get",
    "actions_list",
    "get_job_logs"
  ]
}
