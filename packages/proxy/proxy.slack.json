{
  "upstreams": {
    "slack": {
      "url": "http://slack-mcp:3003/mcp"
    }
  },
  "policy": {
    "rules": [
      { "upstream": "slack", "toolPattern": "post_message", "action": "allow" },
      { "upstream": "slack", "toolPattern": "read_thread", "action": "allow" },
      { "upstream": "slack", "toolPattern": "get_channel_history", "action": "allow" },
      { "upstream": "*", "toolPattern": "*", "action": "block" }
    ]
  }
}
