# Environment variables required for Thor
# Copy this file to .env and fill in the values.

# Linear API key — get from Linear Settings > API > Personal API keys
# Needs read access to your team's workspace.
LINEAR_API_KEY=lin_api_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PostHog personal API key — create at https://app.posthog.com/settings/user-api-keys?preset=mcp_server
# Use the "MCP Server" preset to scope access to a specific project.
POSTHOG_API_KEY=phx_XXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Optional: make the runner connect to a different OpenCode server instead of
# the compose-managed container. From inside Docker, a host instance is usually:
#   http://host.docker.internal:4096
# OPENCODE_URL=http://opencode:4096

# Google SSO credentials for Vouch Proxy (ingress auth)
OAUTH_CLIENT_ID=your-google-client-id
OAUTH_CLIENT_SECRET=your-google-client-secret
SSO_JWT_SECRET=generate-a-random-secret

# Slack app settings for packages/gateway.
# Create a Slack app with an Events API subscription and the `app_mentions:read`
# and `chat:write` bot scopes, then set the bot token + signing secret below.
SLACK_SIGNING_SECRET=
SLACK_BOT_TOKEN=
# Optional:
# SLACK_TIMESTAMP_TOLERANCE_SECONDS=300
